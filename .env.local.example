# Supabase — obtenha em https://app.supabase.com → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-chave-anon-publica

# BRAPI — cotações B3 (ações e FIIs) — gere seu token grátis em https://brapi.dev
# Esta variável é usada APENAS no servidor (sem prefixo NEXT_PUBLIC_)
BRAPI_TOKEN=seu-token-brapi
